# Server Configuration
# Set FLASK_ENV=production when deploying (disables debug).
FLASK_PORT=5000
FLASK_ENV=development

# CORS allowed origins. Use * in dev. In production set your frontend URL,
# e.g. CORS_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=*

# Database Configuration — Firebase Firestore
# Path to the Firebase Admin SDK service account JSON file.
# In production you may instead set FIREBASE_SERVICE_ACCOUNT_JSON to the full JSON string.
FIREBASE_SERVICE_ACCOUNT=lenscape-xxxxx-firebase-adminsdk-xxxxx.json

# Admin master secret key — required to register/login as an admin
ADMIN_SECRET_KEY=change-this-master-key

# JWT signing secrets — CHANGE THESE in production
ADMIN_JWT_SECRET=change-this-admin-secret
USER_JWT_SECRET=change-this-user-secret
OTP_SECRET=change-this-otp-secret

# SMTP2GO Email — used for OTP verification emails
SMTP2GO_API_KEY=your-smtp2go-api-key
SENDER_EMAIL=lenscape@jlug.club

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
