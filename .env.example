# Server Configuration
FLASK_PORT=5000
FLASK_ENV=development

# Database Configuration — Firebase Firestore
# Path to the Firebase Admin SDK service account JSON file
FIREBASE_SERVICE_ACCOUNT=lenscape-xxxxx-firebase-adminsdk-xxxxx.json

# Clerk Authentication Configuration
# Find JWKS URL: https://api.clerk.com/v1/jwks or using your Clerk Instance domain
# e.g., https://clerk.yourdomain.com/.well-known/jwks.json or https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://<your-clerk-instance-id>.clerk.accounts.dev/.well-known/jwks.json

# Admin Emails (comma-separated list)
# Users with these emails will be automatically granted admin capabilities
ADMIN_EMAILS=admin@jlug.club,admin@lenscape.com

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
